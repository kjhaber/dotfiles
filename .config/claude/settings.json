      "Bash(du *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(git blame *)",
      "Bash(git branch *)",
      "Bash(git config get *)",
      "Bash(git config list *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git remote *)",

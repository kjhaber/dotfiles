#!/bin/bash
set -euo pipefail

GLOBAL="$HOME/.config/claude"
LOCAL="$HOME/.config-local/claude"
DEST="$HOME/.claude"

TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

# Merge two JSON files: global + local -> dest
# Arrays are concatenated; scalars in local override global.
# Prompts if dest has drifted from the merged result.
merge_json() {
  local src_global="$1" src_local="$2" dest="$3" label="$4"
  local merged dest_fmt
  merged="$TMP/$(basename "$dest")"
  dest_fmt="$TMP/$(basename "$dest").orig"

  [[ -f "$src_global" ]] || return 0

  if [[ -f "$src_local" ]]; then
    jq -s '
      (.[0]) as $a | (.[1]) as $b |
      $a * $b |
      with_entries(
        .key as $k |
        if ($a[$k] | type) == "array" and ($b[$k] | type) == "array"
        then .value = $a[$k] + $b[$k]
        else . end
      )
    ' "$src_global" "$src_local" | jq -S . > "$merged"
  else
    jq -S . "$src_global" > "$merged"
  fi

  if [[ -f "$dest" ]]; then
    jq -S . "$dest" > "$dest_fmt"
    if ! diff -q "$merged" "$dest_fmt" > /dev/null 2>&1; then
      echo "⚠️  $label has drifted from merged config:"
      diff --color=always "$merged" "$dest_fmt" || true
      echo
      printf "  [o] Overwrite  [k] Keep  [e] Exit: "
      read -r choice
      case "$choice" in
        o) cp "$merged" "$dest" ;;
        k) ;;
        *) exit 1 ;;
      esac
    fi
  else
    cp "$merged" "$dest"
  fi
}

# Merge two directories: global + local -> dest (local wins on conflict).
# Reports files in dest that came from neither source (created via Claude Code).
merge_dir() {
  local src_global="$1" src_local="$2" dest="$3" label="$4"
  local expected="$TMP/${label}_expected.txt"

  mkdir -p "$dest"

  if [[ -d "$src_global" ]]; then
    while IFS= read -r -d '' f; do
      rel="${f#"$src_global"/}"
      cp "$f" "$dest/$rel"
      echo "$rel" >> "$expected"
    done < <(find "$src_global" -name "*.md" -print0 2>/dev/null)
  fi

  if [[ -d "$src_local" ]]; then
    while IFS= read -r -d '' f; do
      rel="${f#"$src_local"/}"
      cp "$f" "$dest/$rel"
      grep -qxF "$rel" "$expected" 2>/dev/null || echo "$rel" >> "$expected"
    done < <(find "$src_local" -name "*.md" -print0 2>/dev/null)
  fi

  # Detect orphans: files in dest not sourced from either dir
  local orphans=()
  while IFS= read -r -d '' f; do
    rel="${f#"$dest"/}"
    grep -qxF "$rel" "$expected" 2>/dev/null || orphans+=("$rel")
  done < <(find "$dest" -name "*.md" -print0 2>/dev/null)

  if [[ ${#orphans[@]} -gt 0 ]]; then
    echo "⚠️  $label/ has files not in either source (created via Claude Code?):"
    printf '    %s\n' "${orphans[@]}"
    echo
    printf "  [k] Keep  [d] Delete  [e] Exit: "
    read -r choice
    case "$choice" in
      d) for f in "${orphans[@]}"; do rm "$DEST/$label/$f"; done ;;
      k) ;;
      *) exit 1 ;;
    esac
  fi
}

# Merge two Markdown files: global then local, separated by a blank line.
# Prompts if dest has drifted from the merged result.
merge_md() {
  local src_global="$1" src_local="$2" dest="$3" label="$4"
  local merged
  merged="$TMP/$(basename "$dest")"

  [[ -f "$src_global" ]] || return 0

  if [[ -f "$src_local" ]]; then
    { cat "$src_global"; echo; cat "$src_local"; } > "$merged"
  else
    cp "$src_global" "$merged"
  fi

  if [[ -f "$dest" ]]; then
    if ! diff -q "$merged" "$dest" > /dev/null 2>&1; then
      echo "⚠️  $label has drifted from merged config:"
      diff --color=always "$merged" "$dest" || true
      echo
      printf "  [o] Overwrite  [k] Keep  [e] Exit: "
      read -r choice
      case "$choice" in
        o) cp "$merged" "$dest" ;;
        k) ;;
        *) exit 1 ;;
      esac
    fi
  else
    cp "$merged" "$dest"
  fi
}

# Markdown files
merge_md "$GLOBAL/CLAUDE.md" "$LOCAL/CLAUDE.md" "$DEST/CLAUDE.md" "CLAUDE.md"

# JSON files
merge_json "$GLOBAL/settings.json"    "$LOCAL/settings.json"    "$DEST/settings.json"    "settings.json"
merge_json "$GLOBAL/keybindings.json" "$LOCAL/keybindings.json" "$DEST/keybindings.json" "keybindings.json"

# Directories (memory/ excluded — auto-generated by Claude, machine-local)
for dir in commands agents skills; do
  if [[ -d "$GLOBAL/$dir" || -d "$LOCAL/$dir" ]]; then
    merge_dir "$GLOBAL/$dir" "$LOCAL/$dir" "$DEST/$dir" "$dir"
  fi
done

exec "$(brew --prefix)/bin/claude" "$@"

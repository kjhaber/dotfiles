#!/usr/bin/env zsh
# __wn-tmux-claude
# Opens Claude Code in a new tmux window using prompt
# of provided 'wn' work item id.
#
# Intended for use with 'wn' work item manager as a
# runner script for 'wn launch' or 'wn do'.  Leading
# underscores are present in script name because I
# don't normally want to run this script directly.
#
# In 'wn settings' in the "runners" block:
# ```
#     "tmux-claude": {
#       "cmd": "wn-tmux-claude {{.Worktree}} {{.ItemID}}",
#       "leave_worktree": true
#     }
# ```
#
# Then run `wn launch tmux-claude` to set Claude Code to
# work on the current wn work item in a new tmux window.

worktree="$1"
item_id="$2"
window_name="wn-${item_id}"

# If a window for this item already exists, switch to it
if tmux list-windows -F "#{window_name}" 2>/dev/null | grep -qx "$window_name"; then
  tmux select-window -t "$window_name"
  exit 0
fi

# WN_ROOT is set in the environment by wn launch
mkdir -p "${worktree}/.claude"
cp ~/.config/claude/wn-worktree-settings.local.json "${worktree}/.claude/settings.local.json"
tmux new-window -d -n "$window_name" -c "$worktree" \
  "claude '/wn-implement ${item_id}' ; zsh"

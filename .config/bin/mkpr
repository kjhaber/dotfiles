#!/bin/bash

# Makes a GitHub PR (pull request).  Creates a remote branch using the current
# branch's name if not found, and detects whether main branch is named "main" or
# "master".

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Get the current branch name
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Check if we're on main/master branch
if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
    echo -e "${RED}Error: You're currently on the $current_branch branch.${NC}"
    echo "Please switch to a topic branch first."
    exit 1
fi

echo -e "${GREEN}Current branch: $current_branch${NC}"

# Check if remote branch exists
echo "Checking for remote branch..."
if git ls-remote --exit-code --heads origin "$current_branch" >/dev/null 2>&1; then
    echo -e "${GREEN}Remote branch found.${NC}"
else
    echo -e "${YELLOW}Remote branch not found.${NC}"
    read -p "Would you like to create the remote branch? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "Pushing to remote..."
        git push -u origin "$current_branch"
        echo -e "${GREEN}Remote branch created successfully.${NC}"
    else
        echo -e "${RED}Cannot create PR without remote branch. Exiting.${NC}"
        exit 1
    fi
fi

# Determine the default branch (main or master)
default_branch="main"
if ! git ls-remote --exit-code --heads origin main >/dev/null 2>&1; then
    if git ls-remote --exit-code --heads origin master >/dev/null 2>&1; then
        default_branch="master"
    fi
fi

echo -e "${GREEN}Creating pull request against $default_branch...${NC}"

# Create the pull request
# This will open your editor for the PR title and description
if gh pr create --base "$default_branch" --head "$current_branch"; then
    echo -e "${GREEN}Pull request created successfully!${NC}"
else
    echo -e "${RED}Failed to create pull request.${NC}"
    exit 1
fi

